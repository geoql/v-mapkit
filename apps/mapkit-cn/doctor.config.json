{
  "preset": "recommended",
  "exclude": [
    "**/node_modules/**",
    "**/.nuxt/**",
    "**/.output/**",
    "app/components/ui/**"
  ],
  "rules": {
    "dead-code/unused-dependency": "off",
    "vue-doctor/security/no-v-html": "off",
    "nuxt-doctor/security/no-secret-in-public-runtime-config": "off"
  }
}
